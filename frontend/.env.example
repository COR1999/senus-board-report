# URL of the Python/FastAPI backend (see backend/docs/frontend-api-routes.md)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Gemini API key, used server-side only by app/api/insights/route.ts to
# generate the AI Board Insights panel's commentary. Never exposed to the
# client. Without it, the panel falls back to static content
# (see lib/insights.ts's FALLBACK_INSIGHTS) rather than failing.
# Deliberately a separate key/project from the backend's own GEMINI_API_KEY
# (financial document extraction) -- independent quota pools, on purpose.
GEMINI_INSIGHTS_API_KEY=

# Optional -- defaults to "gemini-flash-latest". Override if that alias ever
# stops being free-tier eligible, or you want to pin/try a specific model
# (e.g. "gemini-2.5-flash-lite") without a code change.
GEMINI_INSIGHTS_MODEL=

# Local-management-only. Set both of these ONLY in your own .env.local --
# NEVER in Vercel (Production or Preview). Setting them controls two things
# together: (1) whether the Upload/Delete/Approve/Regenerate/Import/Hide
# admin controls even render (ADMIN_UI_ENABLED in lib/data-service.ts), and
# (2) the matching backend's ADMIN_API_KEY (Railway), sent as the
# X-Admin-Key header on every mutating request (see backend's
# app/core/security.py). Since this is a client-side app, both vars are
# NEXT_PUBLIC_ and therefore visible in the bundle to whoever's browser they
# run in -- that's fine for a value that only ever lives on your own machine
# (or one you've deliberately handed the key to for testing), but it must
# never reach the public Vercel deployment's build. Point
# NEXT_PUBLIC_API_URL above at the live Railway URL to manage production
# data from a local `npm run dev`.
NEXT_PUBLIC_ADMIN_API_KEY=
