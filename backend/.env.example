DATABASE_URL=postgresql://user:password@localhost/senus_db
GEMINI_API_KEY=your_gemini_key_here
# Optional -- defaults to gemini-2.5-flash. Any model choice here (pinned
# or "-latest") can lose free-tier eligibility or hit availability issues
# for a given key with no warning (confirmed directly, twice, while fixing
# this default) -- override here if it happens again, no redeploy needed.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_CALLS_PER_MINUTE=10
GEMINI_MAX_CALLS_PER_DAY=1000
ENVIRONMENT=development
DEBUG=False
FRONTEND_URL=http://localhost:3000
# Required (via X-Admin-Key header) on upload/delete/regenerate/approve
# endpoints whenever ENVIRONMENT is not "development" -- see
# app/core/security.py. Leave unset locally; local dev bypasses this check
# entirely. In production, an unset key means those endpoints are simply
# unreachable (fail closed), not open.
ADMIN_API_KEY=