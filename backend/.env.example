DATABASE_URL=postgresql://user:password@localhost/senus_db
GEMINI_API_KEY=your_gemini_key_here
# Optional -- defaults to gemini-2.0-flash. Override if a pinned model ever
# loses free-tier eligibility (this has happened) without needing a redeploy.
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_CALLS_PER_MINUTE=10
GEMINI_MAX_CALLS_PER_DAY=1000
ENVIRONMENT=development
DEBUG=False
FRONTEND_URL=http://localhost:3000